  "response_scale": {
    "type": "likert_5",
    "choices": [
      { "label": "Strongly disagree", "value": 1 },
      { "label": "Disagree", "value": 2 },
      { "label": "Neutral", "value": 3 },
      { "label": "Agree", "value": 4 },
      { "label": "Strongly agree", "value": 5 }
    ]
  },
  "scoring": {
    "question_count": 32,
    "reverse_coding_rule": "If reverse_coded is true, transformed_score = 6 - raw_score.",
    "dimension_percent_rule": "side_percent = side_score / (positive_side_score + negative_side_score)",
    "dominant_letter_rule": "Use the higher side score for each dimension. If tied, break tie toward positive letter and mark tie_flag=true.",
    "output_fields": [
      "type_code",
      "dimension_percentages",
      "strongest_signals"
    ]
  },
  "delivery_rules": {
    "question_order": "fixed_mixed_order",
    "anti_pattern": "Do not place opposite-polarity questions from the same dimension consecutively.",
    "adjacency_rule": "Reject candidate order if question[i].dimension == question[i+1].dimension AND polarity differs (positive vs negative).",
    "shuffle_strategy": "authored_shuffle",
    "max_shuffle_attempts": 200
  },
  "encoded_ingestion_rules": {
    "format_version_prefix": "AT1|",
    "forgiving_parser": true,
    "normalization_steps": [
      "trim leading/trailing whitespace",
      "accept lowercase q tokens and normalize to uppercase",
      "accept token separators '-', ':', '=', '_' and normalize to '-'",
      "collapse repeated delimiters",
      "ignore unknown tokens while collecting warnings"
    ],
    "required_fields": [
      "all question answers"
    ],
    "error_response_contract": {
      "returns_hints": true,
      "hint_fields": [
        "token",
        "error_code",
        "message",
        "suggested_fix"
      ],
      "target_latency_ms": 300
    }
  },
